class Solution {
    public ListNode rotateRight(ListNode head, int k) {
        if (head == null || head.next == null || k == 0) return head;

        // Step 1: Compute the length and get the tail
        ListNode tail = head;
        int length = 1;
        while (tail.next != null) {
            tail = tail.next;
            length++;
        }

        // Step 2: Connect tail to head (circular list)
        tail.next = head;

        // Step 3: Find new tail at (length - k % length - 1)
        int stepsToNewTail = length - k % length;
        ListNode newTail = tail;
        for (int i = 0; i < stepsToNewTail; i++) {
            newTail = newTail.next;
        }

        // Step 4: Break the circle and return new head
        ListNode newHead = newTail.next;
        newTail.next = null;

        return newHead;
    }
}
